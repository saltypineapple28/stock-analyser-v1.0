# Copy this file to .env and fill in your API keys

# NewsAPI - get free key at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# OpenAI - get key at https://platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# Reddit (PRAW) - create app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=StockAnalyzer/1.0

# StockTwits - no key required for public data
